{
    "version": 2,
    "outputDirectory": "client/dist",
    "rewrites": [
        {
            "source": "/api/(.*)",
            "destination": "/server/src/index.ts"
        },
        {
            "source": "/((?!api/|assets/|favicon.ico|vite.svg).*)",
            "destination": "/index.html"
        }
    ]
}