{
    "version": 2,
    "outputDirectory": "client/dist",
    "cleanUrls": true,
    "trailingSlash": false,
    "framework": "vite",
    "routes": [
        {
            "src": "/assets/(.*)",
            "dest": "/assets/$1"
        },
        {
            "src": "/admin(.*)",
            "dest": "/index.html"
        },
        {
            "src": "/waiter(.*)",
            "dest": "/index.html"
        },
        {
            "src": "/menu(.*)",
            "dest": "/index.html"
        },
        {
            "src": "/(.*)",
            "dest": "/index.html"
        }
    ]
}